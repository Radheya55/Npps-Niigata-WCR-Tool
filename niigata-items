// Build a blank maintenance table from a library item (matches existing tool row schema)
function buildMaintTableFromItem(item) {
  return {
    id: "tbl_" + item.id + "_" + Date.now(),
    itemId: item.id,
    nameOfItem: item.name,
    rows: item.activities.map(a => ({
      activity: a, inScope: "", status: "", calibration: "", replaced: "", comment: ""
    })),
    specificNote: "",
    criticalFinding: "",
    actionStep: ""
  };
}

// Blank CUSTOM table (the escape hatch — user types their own name + rows)
function buildCustomMaintTable() {
  return {
    id: "tbl_custom_" + Date.now(),
    itemId: null,
    custom: true,
    nameOfItem: "",
    rows: [{ activity:"", inScope:"", status:"", calibration:"", replaced:"", comment:"" }],
    specificNote: "",
    criticalFinding: "",
    actionStep: ""
  };
}

if (typeof module !== "undefined") module.exports = { NIIGATA_ITEMS, NIIGATA_SECTIONS, buildMaintTableFromItem, buildCustomMaintTable };
